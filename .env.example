# ──────────────────────────────────────────────
# AI Video Agent — Environment Configuration
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# ElevenLabs  (https://elevenlabs.io/settings/api-keys)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB        # "Adam" — change if you prefer another

# OpenAI  (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# YouTube Data API v3
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable "YouTube Data API v3"
# 3. Create OAuth 2.0 credentials (Desktop App)
# 4. Download the JSON file and save as client_secret.json in project root
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json

# ──────────────────────────────────────────────
# OPTIONAL OVERRIDES
# ──────────────────────────────────────────────

# ElevenLabs voice settings
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.50
ELEVENLABS_SIMILARITY=0.80
ELEVENLABS_STYLE=0.25

# OpenAI image settings
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_SIZE=1792x1024
OPENAI_IMAGE_QUALITY=hd

# Video assembly settings
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30
IMAGE_DISPLAY_DURATION=5
FADE_DURATION=0.5
BACKGROUND_MUSIC_VOLUME=0.12

# YouTube upload defaults
YOUTUBE_CATEGORY_ID=28
YOUTUBE_PRIVACY=private
